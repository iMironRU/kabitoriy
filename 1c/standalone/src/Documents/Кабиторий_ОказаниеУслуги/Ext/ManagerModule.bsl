#Область ПрограммныйИнтерфейс

// Создаёт черновик оказания услуги - преднодача-состояние (§5.2).
// Единственная санкционированная точка установки начального состояния Черновик.
//
// Возвращаемое значение:
//   ДокументСсылка.Кабиторий_ОказаниеУслуги - созданный черновик
//
Функция СоздатьЧерновик() Экспорт

	Объект = Документы.Кабиторий_ОказаниеУслуги.СоздатьДокумент();
	Объект.Дата = ТекущаяДатаСеанса();
	Объект.Состояние = Перечисления.Кабиторий_СостоянияОказанияУслуги.Черновик;
	Объект.Записать();

	Кабиторий_ДоменныеСобытия.Опубликовать(
		Перечисления.Кабиторий_ВидыДоменныхСобытий.ЗаявкаСоздана, Объект.Ссылка);

	Возврат Объект.Ссылка;

КонецФункции

// Выполняет защищённый переход состояния оказания услуги.
// Единственная точка смены реквизита Состояние (INV-09).
//
// Параметры:
//   ОказаниеУслугиСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат
//   НовоеСостояние - EnumRef.Кабиторий_СостоянияОказанияУслуги - целевое состояние
//   Контекст - Структура - параметры перехода:
//     * Исход - EnumRef.Кабиторий_ИсходыОказанияУслуги - обязателен при переходе в «Закрыта»
//     * ИгнорироватьБлок - Булево - выполнить переход несмотря на блок (форс центра/админа, §6.2)
//
// Возвращаемое значение:
//   ДокументСсылка.Кабиторий_ОказаниеУслуги - тот же агрегат после фиксации
//
Функция ВыполнитьПереход(ОказаниеУслугиСсылка, НовоеСостояние, Контекст = Неопределено) Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;

	НачатьТранзакцию();
	Попытка

		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Документ.Кабиторий_ОказаниеУслуги");
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ОказаниеУслугиСсылка);
		Блокировка.Заблокировать();

		Объект = ОказаниеУслугиСсылка.ПолучитьОбъект();

		Если ЗначениеЗаполнено(Объект.КодБлока) И НЕ ФорсированиеБлока(Контекст) Тогда
			ВызватьИсключение СтрШаблон(
				"Заявка заблокирована (%1); снимите блок или укажите ИгнорироватьБлок",
				Объект.КодБлока);
		КонецЕсли;

		Если НЕ ПереходДопустим(Объект.Состояние, НовоеСостояние) Тогда
			ВызватьИсключение СтрШаблон(
				"Недопустимый переход: %1 -> %2",
				Объект.Состояние, НовоеСостояние);
		КонецЕсли;

		Если НовоеСостояние = Состояния.Закрыта Тогда
			УстановитьИсходЗакрытия(Объект, Контекст);
		КонецЕсли;

		Объект.Состояние = НовоеСостояние;
		Объект.Записать();

		ОпубликоватьСобытиеПерехода(ОказаниеУслугиСсылка, НовоеСостояние);

		// TODO (следующий слайс): доменная транзакция Акцепта при переходе
		// в «Акцептована» (§6.3) - перенос фактов в профиль, заморозка стоимости.

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

	Возврат ОказаниеУслугиСсылка;

КонецФункции

// Проверяет, разрешён ли переход между состояниями по таблице конечного автомата.
//
// Параметры:
//   ТекущееСостояние - EnumRef.Кабиторий_СостоянияОказанияУслуги
//   НовоеСостояние - EnumRef.Кабиторий_СостоянияОказанияУслуги
//
// Возвращаемое значение:
//   Булево - Истина, если переход допустим
//
Функция ПереходДопустим(ТекущееСостояние, НовоеСостояние) Экспорт

	ДопустимыеЦели = ТаблицаПереходов().Получить(ТекущееСостояние);

	Если ДопустимыеЦели = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ДопустимыеЦели.Найти(НовоеСостояние) <> Неопределено;

КонецФункции

// Устанавливает блок - ортогональную ось поверх состояния (§6.2).
// Замораживает заявку на месте, сохраняет остаток таймера срока.
// Допустим только для активной заявки (не Черновик и не Закрыта).
//
// Параметры:
//   ОказаниеУслугиСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат
//   КодБлока - СправочникСсылка.Кабиторий_ПричиныБлокировок - причина блока
//   ПричинаБлока - Строка - детализация причины
//   Автоснимаемый - Булево - снимается подписчиком/регламентом (Inbox/таймер)
//   ОстатокТаймераСрока - Число - сохранённый остаток срока на входе в блок
//
// Возвращаемое значение:
//   ДокументСсылка.Кабиторий_ОказаниеУслуги - тот же агрегат после фиксации
//
Функция УстановитьБлок(ОказаниеУслугиСсылка, КодБлока, ПричинаБлока = "",
	Автоснимаемый = Ложь, ОстатокТаймераСрока = 0) Экспорт

	Если НЕ ЗначениеЗаполнено(КодБлока) Тогда
		ВызватьИсключение "Не указан код блока";
	КонецЕсли;

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;

	НачатьТранзакцию();
	Попытка

		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Документ.Кабиторий_ОказаниеУслуги");
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ОказаниеУслугиСсылка);
		Блокировка.Заблокировать();

		Объект = ОказаниеУслугиСсылка.ПолучитьОбъект();

		Если Объект.Состояние = Состояния.Черновик Или Объект.Состояние = Состояния.Закрыта Тогда
			ВызватьИсключение СтрШаблон("Блок недопустим в состоянии «%1»", Объект.Состояние);
		КонецЕсли;

		Объект.КодБлока = КодБлока;
		Объект.ПричинаБлока = ПричинаБлока;
		Объект.БлокАвтоснимаемый = Автоснимаемый;
		Объект.ОстатокТаймераСрока = ОстатокТаймераСрока;
		Объект.ДатаБлока = ТекущаяДатаСеанса();
		Объект.АвторБлока = ТекущийПользовательСтрокой();
		Объект.Записать();

		Кабиторий_ДоменныеСобытия.Опубликовать(
			Перечисления.Кабиторий_ВидыДоменныхСобытий.ЗаявкаЗаблокирована, ОказаниеУслугиСсылка);

		// TODO: таймер блока -> эскалация (§6.2)

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

	Возврат ОказаниеУслугиСсылка;

КонецФункции

// Снимает блок. Идемпотентно: повтор на незаблокированной заявке - без эффекта.
//
// Параметры:
//   ОказаниеУслугиСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат
//
// Возвращаемое значение:
//   ДокументСсылка.Кабиторий_ОказаниеУслуги - тот же агрегат после фиксации
//
Функция СнятьБлок(ОказаниеУслугиСсылка) Экспорт

	НачатьТранзакцию();
	Попытка

		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Документ.Кабиторий_ОказаниеУслуги");
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ОказаниеУслугиСсылка);
		Блокировка.Заблокировать();

		Объект = ОказаниеУслугиСсылка.ПолучитьОбъект();

		Если ЗначениеЗаполнено(Объект.КодБлока) Тогда
			Объект.КодБлока = Справочники.Кабиторий_ПричиныБлокировок.ПустаяСсылка();
			Объект.ПричинаБлока = "";
			Объект.БлокАвтоснимаемый = Ложь;
			Объект.ОстатокТаймераСрока = 0;
			Объект.ДатаБлока = '00010101000000';
			Объект.АвторБлока = "";
			Объект.Записать();

			Кабиторий_ДоменныеСобытия.Опубликовать(
				Перечисления.Кабиторий_ВидыДоменныхСобытий.ЗаявкаРазблокирована, ОказаниеУслугиСсылка);

			// TODO: продолжить таймер срока с остатка (§14)
		КонецЕсли;

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

	Возврат ОказаниеУслугиСсылка;

КонецФункции

// Проверяет, заблокирована ли заявка (есть активный код блока).
//
// Параметры:
//   ОказаниеУслугиСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат
//
// Возвращаемое значение:
//   Булево - Истина, если по заявке стоит блок
//
Функция Заблокирована(ОказаниеУслугиСсылка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ОказаниеУслуги.КодБлока КАК КодБлока
		|ИЗ
		|	Документ.Кабиторий_ОказаниеУслуги КАК ОказаниеУслуги
		|ГДЕ
		|	ОказаниеУслуги.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ОказаниеУслугиСсылка);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Если НЕ Выборка.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ЗначениеЗаполнено(Выборка.КодБлока);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает таблицу допустимых переходов: состояние -> массив целевых состояний.
// Позвоночник только вперёд (INV-04). «Закрыта» - терминал, исходящих переходов нет.
// «Черновик» вне позвоночника: единственный переход - Подана (отмена черновика = удаление).
//
// Возвращаемое значение:
//   Соответствие - ключ EnumRef.Кабиторий_СостоянияОказанияУслуги, значение Массив целевых состояний
//
Функция ТаблицаПереходов()

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Переходы = Новый Соответствие;

	Переходы.Вставить(Состояния.Черновик, Цели(Состояния.Подана));
	Переходы.Вставить(Состояния.Подана, Цели(Состояния.НаМодерации, Состояния.Акцептована, Состояния.Закрыта));
	Переходы.Вставить(Состояния.НаМодерации, Цели(Состояния.Акцептована, Состояния.Закрыта));
	Переходы.Вставить(Состояния.Акцептована, Цели(Состояния.Исполнение, Состояния.Закрыта));
	Переходы.Вставить(Состояния.Исполнение, Цели(Состояния.РезультатСформирован, Состояния.Закрыта));
	Переходы.Вставить(Состояния.РезультатСформирован, Цели(Состояния.Подписан, Состояния.Выдан, Состояния.Закрыта));
	Переходы.Вставить(Состояния.Подписан, Цели(Состояния.Выдан, Состояния.Закрыта));
	Переходы.Вставить(Состояния.Выдан, Цели(Состояния.Закрыта));

	Возврат Переходы;

КонецФункции

// Собирает массив целевых состояний (до четырёх).
//
// Параметры:
//   Цель1 - EnumRef.Кабиторий_СостоянияОказанияУслуги - обязательная цель перехода
//   Цель2 - EnumRef.Кабиторий_СостоянияОказанияУслуги - необязательная цель
//   Цель3 - EnumRef.Кабиторий_СостоянияОказанияУслуги - необязательная цель
//   Цель4 - EnumRef.Кабиторий_СостоянияОказанияУслуги - необязательная цель
//
// Возвращаемое значение:
//   Массив - целевые состояния
//
Функция Цели(Знач Цель1, Знач Цель2 = Неопределено, Знач Цель3 = Неопределено, Знач Цель4 = Неопределено)

	Результат = Новый Массив;
	Результат.Добавить(Цель1);

	Если Цель2 <> Неопределено Тогда
		Результат.Добавить(Цель2);
	КонецЕсли;

	Если Цель3 <> Неопределено Тогда
		Результат.Добавить(Цель3);
	КонецЕсли;

	Если Цель4 <> Неопределено Тогда
		Результат.Добавить(Цель4);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Проверяет и проставляет исход при закрытии (§6.3): «Закрыта» одна, различает исход.
//
// Параметры:
//   Объект - ДокументОбъект.Кабиторий_ОказаниеУслуги - изменяемый агрегат
//   Контекст - Структура - параметры перехода; обязательное свойство Исход
//
Процедура УстановитьИсходЗакрытия(Объект, Контекст)

	Если Контекст = Неопределено
		Или НЕ Контекст.Свойство("Исход")
		Или НЕ ЗначениеЗаполнено(Контекст.Исход) Тогда
		ВызватьИсключение "Переход в «Закрыта» требует заполненный Исход в контексте перехода";
	КонецЕсли;

	Объект.Исход = Контекст.Исход;

КонецПроцедуры

// Возвращает Истина, если контекст перехода требует игнорировать блок (форс центра/админа).
//
// Параметры:
//   Контекст - Структура - параметры перехода
//
// Возвращаемое значение:
//   Булево - Истина при ИгнорироватьБлок = Истина в контексте
//
Функция ФорсированиеБлока(Контекст)

	Если Контекст = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Значение = Ложь;
	Контекст.Свойство("ИгнорироватьБлок", Значение);

	Возврат Значение;

КонецФункции

// Возвращает идентификатор текущего пользователя ИБ строкой (UUID).
// TODO: при интеграции БСП - заменить тип DefinedType.Кабиторий_Пользователь на ссылку Пользователи.
//
// Возвращаемое значение:
//   Строка - UUID текущего пользователя ИБ
//
Функция ТекущийПользовательСтрокой()

	ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();

	Возврат Строка(ТекущийПользователь.УникальныйИдентификатор);

КонецФункции

// Публикует доменное событие, соответствующее переходу (если оно определено, §19).
//
// Параметры:
//   ОказаниеУслугиСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат
//   НовоеСостояние - EnumRef.Кабиторий_СостоянияОказанияУслуги - целевое состояние
//
Процедура ОпубликоватьСобытиеПерехода(ОказаниеУслугиСсылка, НовоеСостояние)

	ВидСобытия = ВидСобытияПерехода(НовоеСостояние);
	Если ВидСобытия <> Неопределено Тогда
		Кабиторий_ДоменныеСобытия.Опубликовать(ВидСобытия, ОказаниеУслугиСсылка);
	КонецЕсли;

КонецПроцедуры

// Сопоставляет целевое состояние перехода доменному событию (§19).
//
// Параметры:
//   НовоеСостояние - EnumRef.Кабиторий_СостоянияОказанияУслуги - целевое состояние
//
// Возвращаемое значение:
//   EnumRef.Кабиторий_ВидыДоменныхСобытий, Неопределено - событие или нет
//
Функция ВидСобытияПерехода(НовоеСостояние)

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Виды = Перечисления.Кабиторий_ВидыДоменныхСобытий;

	Соответствие = Новый Соответствие;
	Соответствие.Вставить(Состояния.Подана, Виды.ЗаявкаПодана);
	Соответствие.Вставить(Состояния.Акцептована, Виды.ЗаявкаАкцептована);
	Соответствие.Вставить(Состояния.РезультатСформирован, Виды.РезультатСформирован);
	Соответствие.Вставить(Состояния.Подписан, Виды.РезультатПодписан);
	Соответствие.Вставить(Состояния.Выдан, Виды.РезультатВыдан);
	Соответствие.Вставить(Состояния.Закрыта, Виды.ЗаявкаЗакрыта);

	Возврат Соответствие.Получить(НовоеСостояние);

КонецФункции

#КонецОбласти
