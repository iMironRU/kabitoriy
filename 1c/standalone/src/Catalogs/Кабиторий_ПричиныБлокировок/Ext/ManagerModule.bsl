#Область ПрограммныйИнтерфейс

// Возвращает значение «автоснимаемая» по умолчанию для предопределённой причины (§6.2).
// Автоснимаемые причины снимаются механизмом (Inbox внешнего подтверждения /
// регламент по таймеру), а не оператором вручную.
//
// Параметры:
//   Причина - СправочникСсылка.Кабиторий_ПричиныБлокировок - причина блокировки
//
// Возвращаемое значение:
//   Булево - Истина, если блок по этой причине снимается автоматически
//
Функция АвтоснимаемаяПоУмолчанию(Причина) Экспорт

	Справочник = Справочники.Кабиторий_ПричиныБлокировок;

	Если Причина = Справочник.ОжиданиеОтвета Или Причина = Справочник.ОжиданиеОплаты Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

#КонецОбласти
