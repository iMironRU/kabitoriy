#Область ПрограммныйИнтерфейс

// Выполняет внешний эффект намерения через SPI-коннектор (§16).
// ВНЕ транзакции (INV-10): вызывается исполнителем Outbox между короткими
// транзакциями фиксации статуса. Идемпотентность - по ключу намерения.
//
// Диспетчеризация по ВидЭффекта на конкретный коннектор. Реальные коннекторы -
// внешние обработки, самодекларирующие роль (§16) - TODO. Сейчас встроенная
// заглушка, чтобы замкнуть контур исполнителя.
//
// Параметры:
//   Намерение - Структура - намерение из Outbox (см. РегистрыСведений.
//               Кабиторий_ИсходящиеНамерения.ПолучитьНамерение)
//
// Возвращаемое значение:
//   Структура - ответ SPI: success (Булево), externalRef, reasonCode,
//               reasonDescription (Строка). reasonCode/externalRef непрозрачны.
//
Функция ВыполнитьЭффект(Намерение) Экспорт

	// TODO: выбор коннектора по Намерение.ВидЭффекта (Платеж/Коннектор/Уведомление/
	// СобытиеВовне) и делегирование внешней обработке-плагину (§16).
	Возврат ВызватьЗаглушку(Намерение);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Встроенная заглушка коннектора: имитирует внешний вызов.
// Если в полезной нагрузке есть «ИмитироватьОтказ» = Истина - возвращает отказ
// (для тестов пути ошибки/повторов). Иначе - успех с синтетическим externalRef.
//
// Параметры:
//   Намерение - Структура - намерение из Outbox
//
// Возвращаемое значение:
//   Структура - ответ SPI
//
Функция ВызватьЗаглушку(Намерение)

	Ответ = НовыйОтвет();

	ИмитироватьОтказ = Ложь;
	Нагрузка = Намерение.ПолезнаяНагрузка;
	Если ТипЗнч(Нагрузка) = Тип("Структура") И Нагрузка.Свойство("ИмитироватьОтказ") Тогда
		ИмитироватьОтказ = Нагрузка.ИмитироватьОтказ;
	КонецЕсли;

	Если ИмитироватьОтказ Тогда
		Ответ.reasonCode = "STUB_FAIL";
		Ответ.reasonDescription = "Имитация отказа коннектора (заглушка)";
	Иначе
		Ответ.success = Истина;
		Ответ.externalRef = "STUB-" + Намерение.КлючИдемпотентности;
	КонецЕсли;

	Возврат Ответ;

КонецФункции

// Конструктор пустого ответа SPI (§16).
//
// Возвращаемое значение:
//   Структура - success=Ложь, externalRef/reasonCode/reasonDescription = ""
//
Функция НовыйОтвет() Экспорт

	Возврат Новый Структура("success, externalRef, reasonCode, reasonDescription",
		Ложь, "", "", "");

КонецФункции

#КонецОбласти
