#Область ПрограммныйИнтерфейс

// Публикует доменное событие (§19) и запускает реакции.
// Вызывается ВНУТРИ доменной транзакции операции-источника: внутренние реакции
// синхронны, внешние - через Outbox (намерение пишется в той же транзакции).
//
// Параметры:
//   ВидСобытия - EnumRef.Кабиторий_ВидыДоменныхСобытий - тип события
//   АгрегатСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат-источник
//   Нагрузка - Структура - полезная нагрузка события (по умолчанию пустая)
//
// Возвращаемое значение:
//   Структура - опубликованное событие (контракт §19)
//
Функция Опубликовать(ВидСобытия, АгрегатСсылка, Нагрузка = Неопределено) Экспорт

	Событие = НовоеСобытие(ВидСобытия, АгрегатСсылка, Нагрузка);

	ВыполнитьВнутренниеРеакции(Событие);
	ЗапланироватьВнешниеРеакции(Событие);

	Возврат Событие;

КонецФункции

// Конструктор доменного события (контракт §19).
//
// Параметры:
//   ВидСобытия - EnumRef.Кабиторий_ВидыДоменныхСобытий - тип события
//   АгрегатСсылка - ДокументСсылка.Кабиторий_ОказаниеУслуги - агрегат-источник
//   Нагрузка - Структура - полезная нагрузка (по умолчанию пустая)
//
// Возвращаемое значение:
//   Структура - поля: ИдентификаторСобытия, ВидСобытия, ИдентификаторАгрегата,
//               ВозниклоВ, Версия, Нагрузка
//
Функция НовоеСобытие(ВидСобытия, АгрегатСсылка, Нагрузка = Неопределено) Экспорт

	ФактическаяНагрузка = Нагрузка;
	Если ФактическаяНагрузка = Неопределено Тогда
		ФактическаяНагрузка = Новый Структура;
	КонецЕсли;

	Событие = Новый Структура;
	Событие.Вставить("ИдентификаторСобытия", Строка(Новый УникальныйИдентификатор));
	Событие.Вставить("ВидСобытия", ВидСобытия);
	Событие.Вставить("ИдентификаторАгрегата", АгрегатСсылка);
	Событие.Вставить("ВозниклоВ", ТекущаяДатаСеанса());
	Событие.Вставить("Версия", 1);
	Событие.Вставить("Нагрузка", ФактическаяНагрузка);

	Возврат Событие;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет внутренние синхронные реакции на событие (§19) - в текущей транзакции.
// Точка расширения: сюда подключаются внутренние реакции (напр. пересбор индекса
// сегментов на СтатусКлиентаИзменён). Внешних вызовов здесь быть не должно (INV-10).
//
// Параметры:
//   Событие - Структура - доменное событие
//
Процедура ВыполнитьВнутренниеРеакции(Событие)

	// TODO: подключить внутренние реакции по мере появления (индекс сегментов §7 и т.п.).
	// Сейчас конкретных реакций нет - это точка расширения.
	Возврат;

КонецПроцедуры

// Планирует внешние реакции через Outbox (§19, INV-10): эффект исполнится вне
// транзакции. Ключ идемпотентности привязан к событию, чтобы повтор не дублировал.
//
// Параметры:
//   Событие - Структура - доменное событие
//
Процедура ЗапланироватьВнешниеРеакции(Событие)

	Если ТребуетсяУведомление(Событие.ВидСобытия) Тогда
		ВидЭффекта = Перечисления.Кабиторий_ВидыИсходящихЭффектов.Уведомление;
		Ключ = Событие.ИдентификаторСобытия + ":" + Строка(ВидЭффекта);
		РегистрыСведений.Кабиторий_ИсходящиеНамерения.ЗарегистрироватьНамерение(
			Событие.ИдентификаторАгрегата, ВидЭффекта, Событие, Ключ);
	КонецЕсли;

КонецПроцедуры

// Определяет, нужно ли уведомить клиента по событию (через DeliveryProvider/Outbox).
//
// Параметры:
//   ВидСобытия - EnumRef.Кабиторий_ВидыДоменныхСобытий
//
// Возвращаемое значение:
//   Булево - Истина, если событие порождает уведомление клиента
//
Функция ТребуетсяУведомление(ВидСобытия)

	Виды = Перечисления.Кабиторий_ВидыДоменныхСобытий;

	Уведомляемые = Новый Массив;
	Уведомляемые.Добавить(Виды.ЗаявкаПодана);
	Уведомляемые.Добавить(Виды.ЗаявкаАкцептована);
	Уведомляемые.Добавить(Виды.ЗаявкаОплачена);
	Уведомляемые.Добавить(Виды.РезультатСформирован);
	Уведомляемые.Добавить(Виды.РезультатВыдан);
	Уведомляемые.Добавить(Виды.ЗаявкаЗакрыта);

	Возврат Уведомляемые.Найти(ВидСобытия) <> Неопределено;

КонецФункции

#КонецОбласти
