#Область ПрограммныйИнтерфейс

// Регистрация тестов набора (YAxUnit).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьСерверныйТест("ОбработкаУспехаЗавершаетНамерение")
		.ДобавитьСерверныйТест("ОбработкаОтказаПереводитВОшибку")
		.ДобавитьСерверныйТест("ИсчерпаниеПопытокТребуетРазбора")
		.ДобавитьСерверныйТест("ОбработатьГотовыеДренируетОчередь")
		.ДобавитьСерверныйТест("ЗавершённоеПовторноНеОбрабатывается")
	;

КонецПроцедуры

// Успешный вызов SPI завершает намерение и фиксирует externalRef.
//
Процедура ОбработкаУспехаЗавершаетНамерение() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Ключ = СоздатьНамерение(Ложь);

	Кабиторий_ИсходящиеЭффекты.ОбработатьНамерение(Ключ);

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Завершено);
	ЮТест.ОжидаетЧто(Намерение.ВнешняяСсылка).Равно("STUB-" + Ключ);

КонецПроцедуры

// Отказ коннектора переводит намерение в Ошибка с инкрементом попыток.
//
Процедура ОбработкаОтказаПереводитВОшибку() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Ключ = СоздатьНамерение(Истина);

	Кабиторий_ИсходящиеЭффекты.ОбработатьНамерение(Ключ);

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Ошибка);
	ЮТест.ОжидаетЧто(Намерение.Попыток).Равно(1);
	ЮТест.ОжидаетЧто(Намерение.КодОтказа).Равно("STUB_FAIL");

КонецПроцедуры

// Исчерпание попыток помечает намерение «требует разбора».
//
Процедура ИсчерпаниеПопытокТребуетРазбора() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Ключ = СоздатьНамерение(Истина);

	Для Сч = 1 По 5 Цикл
		Кабиторий_ИсходящиеЭффекты.ОбработатьНамерение(Ключ);
	КонецЦикла;

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.ТребуетРазбора);

КонецПроцедуры

// Дренаж очереди обрабатывает готовые намерения.
//
Процедура ОбработатьГотовыеДренируетОчередь() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Ключ1 = СоздатьНамерение(Ложь);
	Ключ2 = СоздатьНамерение(Ложь);

	Обработано = Кабиторий_ИсходящиеЭффекты.ОбработатьГотовые(100);

	ЮТест.ОжидаетЧто(Обработано >= 2).Равно(Истина);
	Завершено = Перечисления.Кабиторий_СостоянияНамерения.Завершено;
	ЮТест.ОжидаетЧто(Реестр.ПолучитьНамерение(Ключ1).Состояние).Равно(Завершено);
	ЮТест.ОжидаетЧто(Реестр.ПолучитьНамерение(Ключ2).Состояние).Равно(Завершено);

КонецПроцедуры

// Повторная обработка завершённого намерения - без эффекта (идемпотентно).
//
Процедура ЗавершённоеПовторноНеОбрабатывается() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Ключ = СоздатьНамерение(Ложь);

	Кабиторий_ИсходящиеЭффекты.ОбработатьНамерение(Ключ);
	ВнешняяСсылкаПосле1 = Реестр.ПолучитьНамерение(Ключ).ВнешняяСсылка;

	Кабиторий_ИсходящиеЭффекты.ОбработатьНамерение(Ключ);
	Намерение = Реестр.ПолучитьНамерение(Ключ);

	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Завершено);
	ЮТест.ОжидаетЧто(Намерение.ВнешняяСсылка).Равно(ВнешняяСсылкаПосле1);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создаёт намерение для теста (вид «Коннектор»). Управляет ответом заглушки.
//
// Параметры:
//   ИмитироватьОтказ - Булево - заставить заглушку вернуть отказ
//
// Возвращаемое значение:
//   Строка - ключ идемпотентности
//
Функция СоздатьНамерение(ИмитироватьОтказ = Ложь)

	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();
	Нагрузка = Новый Структура("ИмитироватьОтказ", ИмитироватьОтказ);

	Возврат РегистрыСведений.Кабиторий_ИсходящиеНамерения.ЗарегистрироватьНамерение(
		Заявка, Перечисления.Кабиторий_ВидыИсходящихЭффектов.Коннектор, Нагрузка);

КонецФункции

#КонецОбласти
