#Область ПрограммныйИнтерфейс

// Регистрация тестов набора (YAxUnit).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьСерверныйТест("ПервыйРазОбрабатывается")
		.ДобавитьСерверныйТест("ПовторДедуплицируется")
		.ДобавитьСерверныйТест("РазныеСообщенияОбрабатываютсяОба")
		.ДобавитьСерверныйТест("СинтезИдентификатораСтабиленИУникален")
		.ДобавитьСерверныйТест("СинтезТребуетОбаКлюча")
	;

КонецПроцедуры

// Первая обработка сообщения исполняется и фиксируется.
//
Процедура ПервыйРазОбрабатывается() Экспорт

	МессаджИд = "MSG-INBOX-1";

	ОбработаноСейчас = ОбработатьИдемпотентно(МессаджИд);

	ЮТест.ОжидаетЧто(ОбработаноСейчас).Равно(Истина);
	ЮТест.ОжидаетЧто(РегистрыСведений.Кабиторий_ОбработанныеСообщения.СообщениеОбработано(МессаджИд)).Равно(Истина);

КонецПроцедуры

// Повтор того же messageId не переобрабатывается (ровно-один-раз).
//
Процедура ПовторДедуплицируется() Экспорт

	МессаджИд = "MSG-INBOX-DEDUP";

	Первый = ОбработатьИдемпотентно(МессаджИд);
	Второй = ОбработатьИдемпотентно(МессаджИд);

	ЮТест.ОжидаетЧто(Первый).Равно(Истина);
	ЮТест.ОжидаетЧто(Второй).Равно(Ложь);

КонецПроцедуры

// Разные сообщения обрабатываются независимо.
//
Процедура РазныеСообщенияОбрабатываютсяОба() Экспорт

	Первый = ОбработатьИдемпотентно("MSG-A");
	Второй = ОбработатьИдемпотентно("MSG-B");

	ЮТест.ОжидаетЧто(Первый).Равно(Истина);
	ЮТест.ОжидаетЧто(Второй).Равно(Истина);

КонецПроцедуры

// Синтез идентификатора стабилен для одинаковых входов и различает разные.
//
Процедура СинтезИдентификатораСтабиленИУникален() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ОбработанныеСообщения;

	Ключ1 = Реестр.СинтезироватьИдентификатор("PAY", "TX-1");
	Ключ1Повтор = Реестр.СинтезироватьИдентификатор("PAY", "TX-1");
	Ключ2 = Реестр.СинтезироватьИдентификатор("PAY", "TX-2");

	ЮТест.ОжидаетЧто(Ключ1).Равно(Ключ1Повтор);
	ЮТест.ОжидаетЧто(Ключ1 = Ключ2).Равно(Ложь);

КонецПроцедуры

// Синтез без одного из ключей запрещён (защита от слабого ключа).
//
Процедура СинтезТребуетОбаКлюча() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ОбработанныеСообщения;

	ИсключениеБыло = Ложь;
	Попытка
		Реестр.СинтезироватьИдентификатор("PAY", "");
	Исключение
		ИсключениеБыло = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ИсключениеБыло).Равно(Истина);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Идемпотентная обработка сообщения по рецепту Inbox (CLAUDE.md):
// транзакция -> блокировка messageId -> проверка регистра -> эффект + фиксация.
// Возвращает Истина, если эффект исполнен сейчас; Ложь - если дедуп.
//
// Параметры:
//   МессаджИд - Строка - идентификатор сообщения
//
// Возвращаемое значение:
//   Булево - выполнена ли обработка в этом вызове
//
Функция ОбработатьИдемпотентно(МессаджИд)

	Реестр = РегистрыСведений.Кабиторий_ОбработанныеСообщения;
	ОбработаноСейчас = Ложь;

	НачатьТранзакцию();
	Попытка

		Реестр.ЗаблокироватьСообщение(МессаджИд);

		Если НЕ Реестр.СообщениеОбработано(МессаджИд) Тогда
			// Здесь в реальном сценарии - доменный эффект (защищённый переход, фиксация оплаты).
			Реестр.ЗафиксироватьОбработку(МессаджИд, , "тест", "ок");
			ОбработаноСейчас = Истина;
		КонецЕсли;

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

	Возврат ОбработаноСейчас;

КонецФункции

#КонецОбласти
