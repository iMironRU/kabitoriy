#Область ПрограммныйИнтерфейс

// Регистрация тестов набора (YAxUnit).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьСерверныйТест("ЗарегистрироватьСоздаётНовое")
		.ДобавитьСерверныйТест("ИдемпотентныйПовторНеСбрасывает")
		.ДобавитьСерверныйТест("ЖизненныйЦиклУспех")
		.ДобавитьСерверныйТест("ОшибкаУвеличиваетПопытки")
		.ДобавитьСерверныйТест("ПометитьТребуетРазбора")
		.ДобавитьСерверныйТест("ВыбратьГотовыеВключаетНовое")
	;

КонецПроцедуры

// Регистрация намерения создаёт запись в состоянии Новое.
//
Процедура ЗарегистрироватьСоздаётНовое() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();

	Ключ = Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор());
	Намерение = Реестр.ПолучитьНамерение(Ключ);

	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Новое);
	ЮТест.ОжидаетЧто(Намерение.Попыток).Равно(0);
	ЮТест.ОжидаетЧто(Намерение.Заявка).Равно(Заявка);

КонецПроцедуры

// Повторная регистрация с тем же ключом не перезаписывает намерение (дедуп).
//
Процедура ИдемпотентныйПовторНеСбрасывает() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();
	Ключ = "TEST-OUTBOX-DEDUP";

	Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор(), , Ключ);
	Реестр.ОтметитьВОбработке(Ключ);
	Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор(), , Ключ);

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.ВОбработке);

КонецПроцедуры

// Жизненный цикл успеха: Новое -> ВОбработке -> Завершено + externalRef.
//
Процедура ЖизненныйЦиклУспех() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();

	Ключ = Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор());
	Реестр.ОтметитьВОбработке(Ключ);
	Реестр.ЗафиксироватьУспех(Ключ, "EXT-REF-42");

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Завершено);
	ЮТест.ОжидаетЧто(Намерение.ВнешняяСсылка).Равно("EXT-REF-42");

КонецПроцедуры

// Фиксация ошибки увеличивает счётчик попыток и переводит в Ошибка.
//
Процедура ОшибкаУвеличиваетПопытки() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();

	Ключ = Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор());
	Реестр.ЗафиксироватьОшибку(Ключ, "ERR-TIMEOUT", "Таймаут коннектора", 60);

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.Ошибка);
	ЮТест.ОжидаетЧто(Намерение.Попыток).Равно(1);
	ЮТест.ОжидаетЧто(Намерение.КодОтказа).Равно("ERR-TIMEOUT");

КонецПроцедуры

// Пометка требующим разбора переводит в ТребуетРазбора.
//
Процедура ПометитьТребуетРазбора() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();

	Ключ = Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор());
	Реестр.ПометитьТребуетРазбора(Ключ, "Исчерпаны попытки");

	Намерение = Реестр.ПолучитьНамерение(Ключ);
	ЮТест.ОжидаетЧто(Намерение.Состояние).Равно(Перечисления.Кабиторий_СостоянияНамерения.ТребуетРазбора);

КонецПроцедуры

// Fallback-выборка готовых к обработке включает свежее намерение (Новое).
//
Процедура ВыбратьГотовыеВключаетНовое() Экспорт

	Реестр = РегистрыСведений.Кабиторий_ИсходящиеНамерения;
	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();
	Ключ = "READY-" + Строка(Новый УникальныйИдентификатор);

	Реестр.ЗарегистрироватьНамерение(Заявка, ВидКоннектор(), , Ключ);
	Готовые = Реестр.ВыбратьГотовыеКОбработке(100);

	ЮТест.ОжидаетЧто(Готовые.Найти(Ключ) <> Неопределено).Равно(Истина);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Вид эффекта «Коннектор» для тестовых намерений.
//
// Возвращаемое значение:
//   EnumRef.Кабиторий_ВидыИсходящихЭффектов
//
Функция ВидКоннектор()

	Возврат Перечисления.Кабиторий_ВидыИсходящихЭффектов.Коннектор;

КонецФункции

#КонецОбласти
