#Область ПрограммныйИнтерфейс

// Регистрация тестов набора (YAxUnit).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьСерверныйТест("НовоеСобытиеИмеетКонтракт")
		.ДобавитьСерверныйТест("СозданиеНеУведомляет")
		.ДобавитьСерверныйТест("ПодачаПорождаетУведомление")
		.ДобавитьСерверныйТест("ЗакрытиеДобавляетУведомление")
		.ДобавитьСерверныйТест("ЗаблокированнаяНеУведомляетПовторно")
	;

КонецПроцедуры

// Конструктор события содержит контракт §19.
//
Процедура НовоеСобытиеИмеетКонтракт() Экспорт

	Событие = Кабиторий_ДоменныеСобытия.НовоеСобытие(
		Перечисления.Кабиторий_ВидыДоменныхСобытий.ЗаявкаПодана, Неопределено);

	ЮТест.ОжидаетЧто(Событие.Свойство("ИдентификаторСобытия")).Равно(Истина);
	ЮТест.ОжидаетЧто(Событие.Свойство("ВидСобытия")).Равно(Истина);
	ЮТест.ОжидаетЧто(Событие.Свойство("ИдентификаторАгрегата")).Равно(Истина);
	ЮТест.ОжидаетЧто(Событие.Свойство("ВозниклоВ")).Равно(Истина);
	ЮТест.ОжидаетЧто(Событие.Свойство("Нагрузка")).Равно(Истина);
	ЮТест.ОжидаетЧто(Событие.Версия).Равно(1);
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Событие.ИдентификаторСобытия)).Равно(Истина);

КонецПроцедуры

// Создание черновика не порождает внешнего уведомления.
//
Процедура СозданиеНеУведомляет() Экспорт

	Заявка = Документы.Кабиторий_ОказаниеУслуги.СоздатьЧерновик();

	ЮТест.ОжидаетЧто(ЧислоУведомленийПоЗаявке(Заявка)).Равно(0);

КонецПроцедуры

// Подача порождает Outbox-намерение уведомления (переход -> событие -> Outbox).
//
Процедура ПодачаПорождаетУведомление() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Заявка = Менеджер.СоздатьЧерновик();

	Менеджер.ВыполнитьПереход(Заявка, Состояния.Подана);

	ЮТест.ОжидаетЧто(ЧислоУведомленийПоЗаявке(Заявка)).Равно(1);

КонецПроцедуры

// Закрытие добавляет ещё одно уведомление (Подана + Закрыта = 2).
//
Процедура ЗакрытиеДобавляетУведомление() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Исходы = Перечисления.Кабиторий_ИсходыОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Заявка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Заявка, Состояния.Подана);

	Контекст = Новый Структура("Исход", Исходы.Отмена);
	Менеджер.ВыполнитьПереход(Заявка, Состояния.Закрыта, Контекст);

	ЮТест.ОжидаетЧто(ЧислоУведомленийПоЗаявке(Заявка)).Равно(2);

КонецПроцедуры

// Блокировка не порождает уведомления клиента (внутреннее событие).
//
Процедура ЗаблокированнаяНеУведомляетПовторно() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Заявка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Заявка, Состояния.Подана);
	КоличествоДоБлока = ЧислоУведомленийПоЗаявке(Заявка);

	Менеджер.УстановитьБлок(Заявка, Справочники.Кабиторий_ПричиныБлокировок.ОжиданиеОплаты);

	ЮТест.ОжидаетЧто(ЧислоУведомленийПоЗаявке(Заявка)).Равно(КоличествоДоБлока);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает число Outbox-намерений уведомления по заявке.
//
// Параметры:
//   Заявка - ДокументСсылка.Кабиторий_ОказаниеУслуги
//
// Возвращаемое значение:
//   Число - количество намерений вида «Уведомление»
//
Функция ЧислоУведомленийПоЗаявке(Заявка)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(*) КАК Количество
		|ИЗ
		|	РегистрСведений.Кабиторий_ИсходящиеНамерения КАК Намерения
		|ГДЕ
		|	Намерения.Заявка = &Заявка
		|	И Намерения.ВидЭффекта = &ВидЭффекта";
	Запрос.УстановитьПараметр("Заявка", Заявка);
	Запрос.УстановитьПараметр("ВидЭффекта", Перечисления.Кабиторий_ВидыИсходящихЭффектов.Уведомление);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();

	Возврат Выборка.Количество;

КонецФункции

#КонецОбласти
