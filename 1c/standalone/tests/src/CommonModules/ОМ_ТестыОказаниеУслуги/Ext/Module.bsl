#Область ПрограммныйИнтерфейс

// Регистрация тестов набора (YAxUnit).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьСерверныйТест("ПереходЧерновикПодана")
		.ДобавитьСерверныйТест("НедопустимыйПереходОтклоняется")
		.ДобавитьСерверныйТест("ЗакрытиеБезИсходаОтклоняется")
		.ДобавитьСерверныйТест("ЗакрытиеСИсходомФиксируетИсход")
		.ДобавитьСерверныйТест("БлокЗамораживаетПереход")
		.ДобавитьСерверныйТест("ФорсПроходитСквозьБлок")
		.ДобавитьСерверныйТест("УстановитьИСнятьБлок")
		.ДобавитьСерверныйТест("СнятьБлокИдемпотентно")
		.ДобавитьСерверныйТест("ПредопределённыеПричиныСуществуют")
		.ДобавитьСерверныйТест("АвтоснимаемостьПоУмолчанию")
		.ДобавитьСерверныйТест("БлокСПредопределённойПричиной")
	;

КонецПроцедуры

// Черновик -> Подана: допустимый переход двигает состояние.
//
Процедура ПереходЧерновикПодана() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;

	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);

	ЮТест.ОжидаетЧто(Ссылка.Состояние).Равно(Состояния.Подана);

КонецПроцедуры

// Недопустимый переход (Черновик -> Исполнение) отклоняется, состояние не меняется.
//
Процедура НедопустимыйПереходОтклоняется() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();

	ИсключениеБыло = Ложь;
	Попытка
		Менеджер.ВыполнитьПереход(Ссылка, Состояния.Исполнение);
	Исключение
		ИсключениеБыло = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ИсключениеБыло).Равно(Истина);
	ЮТест.ОжидаетЧто(Ссылка.Состояние).Равно(Состояния.Черновик);

КонецПроцедуры

// Переход в Закрыта без Исхода в контексте отклоняется (§6.3).
//
Процедура ЗакрытиеБезИсходаОтклоняется() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);

	ИсключениеБыло = Ложь;
	Попытка
		Менеджер.ВыполнитьПереход(Ссылка, Состояния.Закрыта);
	Исключение
		ИсключениеБыло = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ИсключениеБыло).Равно(Истина);

КонецПроцедуры

// Закрытие с Исходом: состояние Закрыта, исход зафиксирован.
//
Процедура ЗакрытиеСИсходомФиксируетИсход() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Исходы = Перечисления.Кабиторий_ИсходыОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);

	Контекст = Новый Структура("Исход", Исходы.Отмена);
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Закрыта, Контекст);

	ЮТест.ОжидаетЧто(Ссылка.Состояние).Равно(Состояния.Закрыта);
	ЮТест.ОжидаетЧто(Ссылка.Исход).Равно(Исходы.Отмена);

КонецПроцедуры

// Блок замораживает заявку: переход вперёд отклоняется (§6.2).
//
Процедура БлокЗамораживаетПереход() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);
	Менеджер.УстановитьБлок(Ссылка, ПричинаБлокаДляТеста());

	ИсключениеБыло = Ложь;
	Попытка
		Менеджер.ВыполнитьПереход(Ссылка, Состояния.Акцептована);
	Исключение
		ИсключениеБыло = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ИсключениеБыло).Равно(Истина);
	ЮТест.ОжидаетЧто(Ссылка.Состояние).Равно(Состояния.Подана);

КонецПроцедуры

// Форс (ИгнорироватьБлок) проходит сквозь блок (§6.2).
//
Процедура ФорсПроходитСквозьБлок() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);
	Менеджер.УстановитьБлок(Ссылка, ПричинаБлокаДляТеста());

	Контекст = Новый Структура("ИгнорироватьБлок", Истина);
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Акцептована, Контекст);

	ЮТест.ОжидаетЧто(Ссылка.Состояние).Равно(Состояния.Акцептована);

КонецПроцедуры

// УстановитьБлок -> Заблокирована=Истина; СнятьБлок -> Заблокирована=Ложь.
//
Процедура УстановитьИСнятьБлок() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);

	Менеджер.УстановитьБлок(Ссылка, ПричинаБлокаДляТеста());
	ЮТест.ОжидаетЧто(Менеджер.Заблокирована(Ссылка)).Равно(Истина);

	Менеджер.СнятьБлок(Ссылка);
	ЮТест.ОжидаетЧто(Менеджер.Заблокирована(Ссылка)).Равно(Ложь);

КонецПроцедуры

// СнятьБлок на незаблокированной заявке - идемпотентно, без ошибки.
//
Процедура СнятьБлокИдемпотентно() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	Менеджер = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = Менеджер.СоздатьЧерновик();
	Менеджер.ВыполнитьПереход(Ссылка, Состояния.Подана);

	Менеджер.СнятьБлок(Ссылка);

	ЮТест.ОжидаетЧто(Менеджер.Заблокирована(Ссылка)).Равно(Ложь);

КонецПроцедуры

// Предопределённые причины блокировок существуют (стабильные ссылки, §6.2).
//
Процедура ПредопределённыеПричиныСуществуют() Экспорт

	Справочник = Справочники.Кабиторий_ПричиныБлокировок;

	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Справочник.Приостановка)).Равно(Истина);
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Справочник.ОжиданиеДокументов)).Равно(Истина);
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Справочник.Доработка)).Равно(Истина);
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Справочник.ОжиданиеОтвета)).Равно(Истина);
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(Справочник.ОжиданиеОплаты)).Равно(Истина);

КонецПроцедуры

// Автоснимаемость по умолчанию: внешние ожидания - авто, приостановка - ручная.
//
Процедура АвтоснимаемостьПоУмолчанию() Экспорт

	Менеджер = Справочники.Кабиторий_ПричиныБлокировок;

	ЮТест.ОжидаетЧто(Менеджер.АвтоснимаемаяПоУмолчанию(Менеджер.ОжиданиеОплаты)).Равно(Истина);
	ЮТест.ОжидаетЧто(Менеджер.АвтоснимаемаяПоУмолчанию(Менеджер.ОжиданиеОтвета)).Равно(Истина);
	ЮТест.ОжидаетЧто(Менеджер.АвтоснимаемаяПоУмолчанию(Менеджер.Приостановка)).Равно(Ложь);

КонецПроцедуры

// Блок можно поставить с предопределённой причиной.
//
Процедура БлокСПредопределённойПричиной() Экспорт

	Состояния = Перечисления.Кабиторий_СостоянияОказанияУслуги;
	МенеджерУслуги = Документы.Кабиторий_ОказаниеУслуги;
	Ссылка = МенеджерУслуги.СоздатьЧерновик();
	МенеджерУслуги.ВыполнитьПереход(Ссылка, Состояния.Подана);

	МенеджерУслуги.УстановитьБлок(Ссылка, Справочники.Кабиторий_ПричиныБлокировок.ОжиданиеОплаты);

	ЮТест.ОжидаетЧто(МенеджерУслуги.Заблокирована(Ссылка)).Равно(Истина);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создаёт временную причину блокировки для теста.
//
// Возвращаемое значение:
//   СправочникСсылка.Кабиторий_ПричиныБлокировок - причина блока
//
Функция ПричинаБлокаДляТеста()

	Элемент = Справочники.Кабиторий_ПричиныБлокировок.СоздатьЭлемент();
	Элемент.Наименование = "Тест: ожидание оплаты";
	Элемент.Записать();

	Возврат Элемент.Ссылка;

КонецФункции

#КонецОбласти
